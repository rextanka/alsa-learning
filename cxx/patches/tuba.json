{
  "version": 3,
  "name": "Tuba",
  "groups": [{
    "id": 0,
    "comment": "Roland System 100M Fig 1-6 Tuba variant: VCO (saw, 32') → VCF → VCA. footage=32 shifts pitch down 2 octaves (-24 semitones) for the sub-bass tuba register. Shorter ADSR (A=20ms D=20ms S=60% R=20ms) per book. Lower VCF cutoff (1500Hz) for dark tubby character.",
    "chain": [
      {"type": "MIDI_CV",              "tag": "KBD"},
      {"type": "COMPOSITE_GENERATOR", "tag": "VCO"},
      {"type": "ADSR_ENVELOPE",        "tag": "ENV"},
      {"type": "CV_SPLITTER",          "tag": "SPL"},
      {"type": "CV_SCALER",            "tag": "VMOD"},
      {"type": "SH_FILTER",            "tag": "VCF"},
      {"type": "VCA",                  "tag": "VCA"}
    ],
    "connections": [
      {"from_tag":"VCO", "from_port":"audio_out",    "to_tag":"VCF",  "to_port":"audio_in"},
      {"from_tag":"VCF", "from_port":"audio_out",    "to_tag":"VCA",  "to_port":"audio_in"},
      {"from_tag":"ENV", "from_port":"envelope_out", "to_tag":"SPL",  "to_port":"cv_in"},
      {"from_tag":"SPL", "from_port":"cv_out_1",     "to_tag":"VCA",  "to_port":"gain_cv"},
      {"from_tag":"SPL", "from_port":"cv_out_2",     "to_tag":"VMOD", "to_port":"cv_in"},
      {"from_tag":"VMOD","from_port":"cv_out",       "to_tag":"VCF",  "to_port":"cutoff_cv"},
      {"from_tag":"KBD", "from_port":"pitch_cv",     "to_tag":"VCO",  "to_port":"pitch_base_cv"},
      {"from_tag":"KBD", "from_port":"gate_cv",      "to_tag":"ENV",  "to_port":"gate_cv"},
      {"from_tag":"KBD", "from_port":"velocity_cv",  "to_tag":"VCA",  "to_port":"initial_gain_cv"}
    ],
    "parameters": {
      "VCO":  {"saw_gain": 1.0, "footage": 32},
      "VCF":  {"cutoff": 1500.0, "resonance": 0.15},
      "ENV":  {"attack": 0.02, "decay": 0.02, "sustain": 0.60, "release": 0.02},
      "VMOD": {"scale": 0.5}
    }
  }],
  "post_chain": [
    {"type": "REVERB_FREEVERB", "parameters": {"room_size": 0.65, "damping": 0.7, "wet": 0.25}}
  ]
}
