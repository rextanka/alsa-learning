{
  "version": 3,
  "name": "Acid Reverb",
  "groups": [
    {
      "id": 0,
      "comment": "TB-303 faithful: saw → diode filter → VCA → distortion → FDN reverb. AD envelope sweeps filter cutoff only. GATE ADSR (A=0, S=1, R=5ms) gives VCA a micro-release to prevent hard-cut click at note-off, matching the 303 RC gate circuit.",
      "chain": [
        { "type": "MIDI_CV",             "tag": "KBD"  },
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO"  },
        { "type": "DIODE_FILTER",        "tag": "VCF"  },
        { "type": "AD_ENVELOPE",         "tag": "ENV"  },
        { "type": "ADSR_ENVELOPE",       "tag": "GATE" },
        { "type": "VCA",                 "tag": "VCA"  },
        { "type": "DISTORTION",          "tag": "DIST" }
      ],
      "connections": [
        { "from_tag": "KBD",  "from_port": "pitch_cv",    "to_tag": "VCO",  "to_port": "pitch_base_cv" },
        { "from_tag": "KBD",  "from_port": "gate_cv",     "to_tag": "GATE", "to_port": "gate_cv"       },
        { "from_tag": "KBD",  "from_port": "velocity_cv", "to_tag": "VCA",  "to_port": "initial_gain_cv" },
        { "from_tag": "VCO",  "from_port": "audio_out",    "to_tag": "VCF",  "to_port": "audio_in"  },
        { "from_tag": "VCF",  "from_port": "audio_out",    "to_tag": "VCA",  "to_port": "audio_in"  },
        { "from_tag": "ENV",  "from_port": "envelope_out", "to_tag": "VCF",  "to_port": "cutoff_cv" },
        { "from_tag": "GATE", "from_port": "envelope_out", "to_tag": "VCA",  "to_port": "gain_cv"   },
        { "from_tag": "VCA",  "from_port": "audio_out",    "to_tag": "DIST", "to_port": "audio_in"  }
      ],
      "parameters": {
        "VCO":  { "saw_gain": 1.0 },
        "VCF":  { "cutoff": 800.0, "resonance": 0.92, "env_depth": 6.0 },
        "DIST": { "drive": 8.0, "character": 0.3 },
        "ENV":  { "attack": 0.003, "decay": 0.25 },
        "GATE": { "attack": 0.0, "decay": 0.0, "sustain": 1.0, "release": 0.005 }
      }
    }
  ],
  "post_chain": [
    { "type": "REVERB_FDN", "parameters": { "decay": 1.2, "wet": 0.10, "room_size": 0.5, "damping": 0.4 } }
  ]
}
