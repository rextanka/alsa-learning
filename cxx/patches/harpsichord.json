{
  "version": 3,
  "name": "Harpsichord",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M style harpsichord (M-110/M-120/M-130): pulse VCO, ENV drives VCA amplitude and (via INV) modulates PWM for timbral pluck, HPF removes bass muddiness. VCF is static.",
      "chain": [
        {
          "type": "MIDI_CV",
          "tag": "KBD"
        },
        {
          "type": "COMPOSITE_GENERATOR",
          "tag": "VCO"
        },
        {
          "type": "HIGH_PASS_FILTER",
          "tag": "HPF"
        },
        {
          "type": "MOOG_FILTER",
          "tag": "VCF"
        },
        {
          "type": "ADSR_ENVELOPE",
          "tag": "ENV"
        },
        {
          "type": "INVERTER",
          "tag": "INV"
        },
        {
          "type": "VCA",
          "tag": "VCA"
        }
      ],
      "connections": [
        {
          "from_tag": "KBD",
          "from_port": "pitch_cv",
          "to_tag": "VCO",
          "to_port": "pitch_base_cv"
        },
        {
          "from_tag": "KBD",
          "from_port": "gate_cv",
          "to_tag": "ENV",
          "to_port": "gate_cv"
        },
        {
          "from_tag": "KBD",
          "from_port": "velocity_cv",
          "to_tag": "VCA",
          "to_port": "initial_gain_cv"
        },
        {
          "from_tag": "VCO",
          "from_port": "audio_out",
          "to_tag": "HPF",
          "to_port": "audio_in"
        },
        {
          "from_tag": "HPF",
          "from_port": "audio_out",
          "to_tag": "VCF",
          "to_port": "audio_in"
        },
        {
          "from_tag": "VCF",
          "from_port": "audio_out",
          "to_tag": "VCA",
          "to_port": "audio_in"
        },
        {
          "from_tag": "ENV",
          "from_port": "envelope_out",
          "to_tag": "VCA",
          "to_port": "gain_cv"
        },
        {
          "from_tag": "ENV",
          "from_port": "envelope_out",
          "to_tag": "INV",
          "to_port": "cv_in"
        },
        {
          "from_tag": "INV",
          "from_port": "cv_out",
          "to_tag": "VCO",
          "to_port": "pwm_cv"
        }
      ],
      "parameters": {
        "VCO": {
          "pulse_gain": 1.0,
          "pulse_width": 0.5,
          "noise_gain": 0.08
        },
        "HPF": {
          "cutoff": 300.0,
          "resonance": 0.1
        },
        "VCF": {
          "cutoff": 2400.0,
          "resonance": 0.35
        },
        "ENV": {
          "attack": 0.001,
          "decay": 0.65,
          "sustain": 0.0,
          "release": 0.6
        },
        "INV": {
          "scale": -0.8
        }
      }
    }
  ],
  "post_chain": [
    {
      "type": "REVERB_FREEVERB",
      "parameters": {
        "room_size": 0.4,
        "damping": 0.7,
        "wet": 0.15
      }
    }
  ]
}
