{
  "version": 2,
  "name": "Simple Recorder",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M Fig. 1-4. Simple recorder: VCO (square/pulse) → VCA directly, no VCF. Linear VCA mode for natural breath-like amplitude response. Soft attack (30ms) emulates the breath onset. Full sustain, short release. See Fig. 1-7 for improved recorder with filter.",
      "chain": [
        { "type": "MIDI_CV",             "tag": "KBD" },
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO" },
        { "type": "ADSR_ENVELOPE",       "tag": "ENV" },
        { "type": "VCA",                 "tag": "VCA" }
      ],
      "connections": [
        { "from_tag": "VCO", "from_port": "audio_out",    "to_tag": "VCA", "to_port": "audio_in"        },
        { "from_tag": "ENV", "from_port": "envelope_out", "to_tag": "VCA", "to_port": "gain_cv"         },
        { "from_tag": "KBD", "from_port": "pitch_cv",     "to_tag": "VCO", "to_port": "pitch_base_cv"   },
        { "from_tag": "KBD", "from_port": "gate_cv",      "to_tag": "ENV", "to_port": "gate_cv"         },
        { "from_tag": "KBD", "from_port": "velocity_cv",  "to_tag": "VCA", "to_port": "initial_gain_cv" }
      ],
      "parameters": {
        "VCO": { "sine_gain": 1.0, "footage": 4 },
        "ENV": { "attack": 0.03, "decay": 0.0, "sustain": 1.0, "release": 0.1 },
        "VCA": { "response_curve": 0.0 }
      }
    }
  ]
}
