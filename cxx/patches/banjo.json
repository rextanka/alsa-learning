{
  "version": 3,
  "name": "Banjo",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M Fig 3-4 Repeating Trigger: VCO → VCF → VCA. LFO square wave re-triggers ADSR at strum rate via ext_gate_in, producing a rapid repeated pluck while key is held. On the original, a CV_MIXER biases the LFO negative (−10V) so it only triggers when the keyboard gate pulse cancels the bias — replicated here by the ADSR lifecycle gate keeping the envelope quiet between notes. ADSR → VCA only; VCF tracks keyboard pitch. Sawtooth oscillator for rich harmonic content of plucked metal strings.",
      "chain": [
        { "type": "LFO",                 "tag": "LFO" },
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO" },
        { "type": "SH_FILTER",           "tag": "VCF" },
        { "type": "ADSR_ENVELOPE",       "tag": "ENV" },
        { "type": "VCA",                 "tag": "VCA" }
      ],
      "connections": [
        { "from_tag": "VCO", "from_port": "audio_out",    "to_tag": "VCF", "to_port": "audio_in"    },
        { "from_tag": "VCF", "from_port": "audio_out",    "to_tag": "VCA", "to_port": "audio_in"    },
        { "from_tag": "LFO", "from_port": "control_out",  "to_tag": "ENV", "to_port": "ext_gate_in" },
        { "from_tag": "ENV", "from_port": "envelope_out", "to_tag": "VCA", "to_port": "gain_cv"     }
      ],
      "parameters": {
        "VCO": { "saw_gain": 1.0 },
        "LFO": { "waveform": 2, "rate": 2.5, "intensity": 1.0 },
        "VCF": { "cutoff": 2500.0, "resonance": 0.3 },
        "ENV": { "attack": 0.001, "decay": 0.10, "sustain": 0.15, "release": 0.05 }
      }
    }
  ],
  "post_chain": [
    { "type": "REVERB_FREEVERB", "parameters": { "room_size": 0.3, "damping": 0.7, "wet": 0.15 } }
  ]
}
