{
  "version": 3,
  "name": "Oboe",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M Fig 1-9 Oboe variant: VCO (pulse 35%) → MOOG_FILTER (cutoff 1200Hz, res=0.92) → HPF (fixed switch '1'≈250Hz) → VCA. MOOG_FILTER chosen over SH_FILTER for tanh saturation at high resonance — gives the buzzy, reedy double-reed character SH_FILTER cannot. HPF slightly suppresses fundamental per book ('less full than English Horn'). Keyboard CV auto-tracked into VCF. ADSR drives VCA amplitude only.",
      "chain": [
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO" },
        { "type": "MOOG_FILTER",          "tag": "VCF" },
        { "type": "HIGH_PASS_FILTER",    "tag": "HPF" },
        { "type": "ADSR_ENVELOPE",       "tag": "ENV" },
        { "type": "VCA",                 "tag": "VCA" }
      ],
      "connections": [
        {
          "from_tag": "VCO", "from_port": "audio_out",
          "to_tag":   "VCF", "to_port":   "audio_in"
        },
        {
          "from_tag": "VCF", "from_port": "audio_out",
          "to_tag":   "HPF", "to_port":   "audio_in"
        },
        {
          "from_tag": "HPF", "from_port": "audio_out",
          "to_tag":   "VCA", "to_port":   "audio_in"
        },
        {
          "from_tag": "ENV", "from_port": "envelope_out",
          "to_tag":   "VCA", "to_port":   "gain_cv"
        }
      ],
      "parameters": {
        "VCO": { "pulse_gain": 1.0, "pulse_width": 0.35 },
        "VCF": { "cutoff": 1200.0, "resonance": 0.92 },
        "HPF": { "cutoff": 250.0,  "resonance": 0.0 },
        "ENV": { "attack": 0.03, "decay": 0.1, "sustain": 0.85, "release": 0.15 }
      }
    }
  ],
  "post_chain": [
    {
      "type": "REVERB_FREEVERB",
      "parameters": { "room_size": 0.55, "damping": 0.6, "wet": 0.2 }
    }
  ]
}
