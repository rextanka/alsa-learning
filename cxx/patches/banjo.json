{
  "version": 3,
  "name": "Banjo",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M Fig 3-4 Repeating Trigger (faithful): KBD gate_cv + LFO square → CV_MIXER with -0.6 offset (≡ Roland -10V bias) → ADSR gate_cv. Without key held, LFO+bias peaks at +0.4 (below threshold) — silent. With key held, gate lifts sum to +1.0 — LFO re-triggers ADSR at strum rate. KBD pitch_cv → VCF kybd_cv for explicit filter tracking. ADSR → VCA only.",
      "chain": [
        { "type": "MIDI_CV",             "tag": "KBD" },
        { "type": "LFO",                 "tag": "LFO" },
        { "type": "CV_MIXER",            "tag": "MIX" },
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO" },
        { "type": "SH_FILTER",           "tag": "VCF" },
        { "type": "ADSR_ENVELOPE",       "tag": "ENV" },
        { "type": "VCA",                 "tag": "VCA" }
      ],
      "connections": [
        { "from_tag": "VCO", "from_port": "audio_out",    "to_tag": "VCF", "to_port": "audio_in"    },
        { "from_tag": "VCF", "from_port": "audio_out",    "to_tag": "VCA", "to_port": "audio_in"    },
        { "from_tag": "LFO", "from_port": "control_out",  "to_tag": "MIX", "to_port": "cv_in_1"     },
        { "from_tag": "KBD", "from_port": "gate_cv",      "to_tag": "MIX", "to_port": "cv_in_2"     },
        { "from_tag": "MIX", "from_port": "cv_out",       "to_tag": "ENV", "to_port": "gate_cv"     },
        { "from_tag": "ENV", "from_port": "envelope_out", "to_tag": "VCA", "to_port": "gain_cv"     },
        { "from_tag": "KBD", "from_port": "pitch_cv",     "to_tag": "VCF", "to_port": "kybd_cv"    }
      ],
      "parameters": {
        "VCO": { "saw_gain": 1.0 },
        "LFO": { "waveform": 2, "rate": 2.5, "intensity": 1.0 },
        "MIX": { "gain_1": 1.0, "gain_2": 1.0, "offset": -0.6 },
        "VCF": { "cutoff": 2500.0, "resonance": 0.3 },
        "ENV": { "attack": 0.001, "decay": 0.10, "sustain": 0.15, "release": 0.05 }
      }
    }
  ],
  "post_chain": [
    { "type": "REVERB_FREEVERB", "parameters": { "room_size": 0.3, "damping": 0.7, "wet": 0.15 } }
  ]
}
