{
  "version": 3,
  "name": "Violin (Vibrato)",
  "groups": [
    {
      "id": 0,
      "comment": "Roland System 100M Fig. 2-2. VCO (saw, 8') → SH_FILTER (LP, 1600Hz) → VCA ← ADSR. LFO vibrato with 0.5s delayed onset — LFO.delay resets on each note-on so vibrato fades in after the attack. KBD pitch_cv → VCO, gate_cv → ENV.",
      "chain": [
        { "type": "MIDI_CV",             "tag": "KBD"  },
        { "type": "LFO",                 "tag": "LFO1" },
        { "type": "COMPOSITE_GENERATOR", "tag": "VCO"  },
        { "type": "ADSR_ENVELOPE",       "tag": "ENV"  },
        { "type": "SH_FILTER",           "tag": "VCF"  },
        { "type": "VCA",                 "tag": "VCA"  }
      ],
      "connections": [
        { "from_tag": "KBD",  "from_port": "pitch_cv",     "to_tag": "VCO",  "to_port": "pitch_base_cv"   },
        { "from_tag": "KBD",  "from_port": "gate_cv",      "to_tag": "ENV",  "to_port": "gate_cv"         },
        { "from_tag": "KBD",  "from_port": "velocity_cv",  "to_tag": "VCA",  "to_port": "initial_gain_cv" },
        { "from_tag": "LFO1", "from_port": "control_out",  "to_tag": "VCO",  "to_port": "pitch_cv"        },
        { "from_tag": "VCO",  "from_port": "audio_out",    "to_tag": "VCF",  "to_port": "audio_in"        },
        { "from_tag": "ENV",  "from_port": "envelope_out", "to_tag": "VCA",  "to_port": "gain_cv"         },
        { "from_tag": "VCF",  "from_port": "audio_out",    "to_tag": "VCA",  "to_port": "audio_in"        }
      ],
      "parameters": {
        "VCO":  { "saw_gain": 1.0, "sub_gain": 0.2 },
        "VCF":  { "cutoff": 1600.0, "resonance": 0.1 },
        "ENV":  { "attack": 0.3, "decay": 0.0, "sustain": 1.0, "release": 0.4 },
        "LFO1": { "rate": 5.5, "intensity": 0.003, "delay": 0.5 }
      }
    }
  ],
  "post_chain": [
    { "type": "REVERB_FREEVERB", "parameters": { "room_size": 0.55, "damping": 0.6, "wet": 0.2 } }
  ]
}
